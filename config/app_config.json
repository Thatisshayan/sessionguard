{
  "app_name": "SessionGuard",
  "version": "1.5.0",
  "environment": "local",
  "backend": {
    "host": "127.0.0.1",
    "port": 8000,
    "reload": true
  },
  "frontend": {
    "host": "localhost",
    "port": 5173,
    "api_base_url": "http://127.0.0.1:8000"
  },
  "database": {
    "engine": "sqlite",
    "path": "config/sessionguard.db",
    "future_postgres_url": "postgresql://user:pass@localhost/sessionguard"
  },
  "auth": {
    "secret_key": "",
    "access_token_expire_minutes": 60,
    "refresh_token_expire_days": 30
  },
  "storage": {
    "uploads_dir": "storage/uploads",
    "exports_dir": "storage/exports",
    "recordings_dir": "storage/recordings"
  },
  "thresholds": {
    "rtp_warning": 96.0,
    "rtp_critical": 85.0,
    "max_loss": 200.0,
    "streak_warning": 8,
    "streak_critical": 15
  },
  "ocr": {
    "enabled": true,
    "backend": "tesseract",
    "confidence_threshold": 0.75,
    "scale": 2.0
  },
  "ffmpeg": {
    "frame_extraction_fps": 1.0
  },
  "workers": {
    "max_threads": 4,
    "max_retries": 2
  },
    "ai": {
        "nvidia_api_key": "",
        "model": "nvidia/llama-3.1-nemotron-70b-instruct",
        "note": "SECURITY: Use NVIDIA_API_KEY environment variable instead. Never commit real keys to config files.",
        "max_tokens": 1024,
        "cost_per_million_input": 0.12,
        "cost_per_million_output": 0.12,
        "budget_usd": 0.001,
        "ollama_model": "llama3.2:latest",
        "ollama_url": "http://localhost:11434"
    },
  "github": {
    "owner": "Thatisshayan",
    "repo": "sessionguard",
    "releases_url": "https://api.github.com/repos/Thatisshayan/sessionguard/releases/latest"
  },
  "updater": {
    "check_on_startup": true,
    "check_interval_hours": 4,
    "pubkey": ""
  }
}
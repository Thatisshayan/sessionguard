# SessionGuard Environment Variables
# Copy this to .env and fill in your values (never commit .env to git)

# Anthropic API Key - Get from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional: CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://example.com

# Optional: Database URL for PostgreSQL (defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost/sessionguard

# Optional: Additional configuration
# DEBUG=false
# LOG_LEVEL=info

# SessionGuard Environment Variables
# Copy this to .env and fill in your values (never commit .env to git)

# NVIDIA NIM API Key - Get from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE

# Optional: NVIDIA Model ID (default: nvidia/llama-3.1-nemotron-70b-instruct)
# Available: nvidia/llama-3.1-nemotron-70b-instruct, nvidia/llama-3.3-70b-instruct,
#            nvidia/mistral-large-2-instruct, meta/llama-3.1-405b-instruct,
#            mistralai/mistral-large-2-instruct
# NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Optional: CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://example.com

# Optional: Database URL for PostgreSQL (defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost/sessionguard

# Optional: Additional configuration
# DEBUG=false
# LOG_LEVEL=info

{
  "build": {
    "beforeDevCommand":   "",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devPath":            "http://localhost:5173",
    "distDir":            "../../frontend/dist"
  },
  "package": {
    "productName": "SessionGuard",
    "version":     "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "window": { "all": true },
      "dialog": { "all": true },
      "notification": { "all": true },
      "http": { "all": true, "scope": ["http://127.0.0.1:8000/**"] }
    },
    "externalBin": [
      "bundled/tesseract",
      "bundled/ffmpeg",
      "bundled/python"
    ],
    "resources": {
      "bundled/**/*": "bundled/"
    },
    "bundle": {
      "active":     true,
      "targets":    ["msi", "nsis", "app", "dmg", "appimage", "deb", "rpm"],
      "identifier": "com.sessionguard.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "copyright":        "2025 SessionGuard",
      "category":         "Business",
      "shortDescription": "Session intelligence platform",
      "signing": {
        "windows": {
          "identity": null,
          "timestamp_url": "http://timestamp.digicert.com",
          "digest_algorithm": "sha256"
        },
        "macOS": {
          "identity": null,
          "timestamp": "=timestamp",
          "hardened_runtime": true,
          "entitlements": null
        }
      }
    },
    "security": { "csp": null },
    "updater":   {
      "active": true,
      "endpoints": ["https://github.com/Thatisshayan/sessionguard/releases/latest/download/latest.json"],
      "pubkey": ""
    },
    "systemTray": {
      "iconPath":        "icons/32x32.png",
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "title":      "SessionGuard",
        "label":      "main",
        "width":      1440,
        "height":     900,
        "minWidth":   1024,
        "minHeight":  600,
        "resizable":  true,
        "center":     true,
        "decorations": true,
        "visible":    true
      }
    ]
  }
}
